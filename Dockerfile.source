# Build from source (no prebuilt release required).
#
#   docker build -f Dockerfile.source -t anthropic-proxy .
FROM rust:1-slim-bookworm AS builder

WORKDIR /build
COPY . .
RUN cargo build --release --locked \
    && strip target/release/anthropic-proxy

FROM debian:bookworm-slim

RUN apt-get update \
    && apt-get install -y --no-install-recommends ca-certificates \
    && rm -rf /var/lib/apt/lists/*

COPY --from=builder /build/target/release/anthropic-proxy /usr/local/bin/

EXPOSE 3000

ENTRYPOINT ["anthropic-proxy"]
